{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "noCheck": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "index.ts",
    "provider.ts",
    "src/**/*.ts",
    "src/vendor/**/*.mjs",
    "vendor-shims.d.ts"
  ],
  "exclude": ["node_modules", "dist", "tests"]
}
